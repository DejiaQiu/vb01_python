# Container runtime params
MONITOR_ELEVATOR_ID=elevator-001
MONITOR_DEVICE_NAME=elevator-monitor
MONITOR_PORT=/dev/ttyUSB0
MONITOR_BAUD=115200
MONITOR_ADDR=0x50
MONITOR_SAMPLE_HZ=40
MONITOR_DETECT_HZ=40
MONITOR_REG_ADDR=0x34
MONITOR_REG_COUNT=13
MONITOR_MAX_DATA_AGE_MS=500
MONITOR_RECONNECT_NO_DATA_S=8
MONITOR_RECONNECT_BACKOFF_S=2
MONITOR_LOG_LEVEL=INFO
MONITOR_FAULT_TYPE_ENABLED=true
MONITOR_FAULT_TYPE_MIN_LEVEL=warning
MONITOR_FAULT_TYPE_TOP_K=3
MONITOR_FAULT_BASELINE_SIZE=2000
MONITOR_FAULT_BASELINE_MIN_RECORDS=120
MONITOR_FAULT_VIBRATION_WARNING_Z=3.0
MONITOR_FAULT_VIBRATION_SHOCK_Z=6.0
MONITOR_FAULT_TEMP_RISE_C=6.0
MONITOR_FAULT_TEMP_OVERHEAT_C=45.0
MONITOR_FAULT_MODEL_PATH=
MONITOR_FAULT_MODEL_MIN_CONFIDENCE=0.60
MONITOR_FAULT_MODEL_TOP_K=3
MONITOR_FAULT_FUSION_MODE=rule_primary
MONITOR_GENERATED_ALGO_PATH=
MONITOR_GENERATED_ALGO_MIN_CONFIDENCE=0.62
MONITOR_GENERATED_ALGO_TOP_K=3
MONITOR_GENERATED_ALGO_HORIZON_S=30
MONITOR_GENERATED_ALGO_FORECAST_MIN_POINTS=10
MONITOR_RISK_ENABLED=true
MONITOR_RISK_EMIT_ON_NORMAL=true
MONITOR_RISK_EMIT_MIN_LEVEL=high
MONITOR_RISK_BASELINE_SIZE=3000
MONITOR_RISK_BASELINE_MIN_RECORDS=200
MONITOR_RISK_TREND_WINDOW_S=1800
MONITOR_RISK_SMOOTH_ALPHA=0.08
MONITOR_RISK_ANOMALY_SCALE=8.0
MONITOR_RISK_FAULT_WEIGHT=0.25
MONITOR_RISK_VIBRATION_WEIGHT=0.20
MONITOR_RISK_TEMPERATURE_WEIGHT=0.10
MONITOR_RISK_MODEL_PATH=
MONITOR_RISK_MODEL_POSITIVE_LABEL=1
MONITOR_RISK_MODEL_WEIGHT=0.35
MONITOR_MODEL_WINDOW_S=10
MONITOR_MODEL_WINDOW_MIN_SAMPLES=20
MONITOR_DIFY_ENABLED=false
MONITOR_DIFY_BASE_URL=
MONITOR_DIFY_API_KEY=
MONITOR_DIFY_USER=elevator-monitor
MONITOR_DIFY_RESPONSE_MODE=blocking
MONITOR_DIFY_TIMEOUT_S=8
MONITOR_DIFY_VERIFY_SSL=true
MONITOR_DIFY_MIN_LEVEL=warning
MONITOR_DIFY_COOLDOWN_S=30
MONITOR_DIFY_SITE_NAME=
MONITOR_DIFY_MANIFEST_JSON=
MONITOR_EDGE_SYNC_ENABLED=false
MONITOR_EDGE_SYNC_BASE_URL=
MONITOR_EDGE_SYNC_API_TOKEN=
MONITOR_EDGE_SYNC_SITE_ID=
MONITOR_EDGE_SYNC_SITE_NAME=
MONITOR_EDGE_SYNC_DEVICE_ID=
MONITOR_EDGE_SYNC_QUEUE_PATH=/app/data/edge_sync_queue.sqlite3
MONITOR_EDGE_SYNC_HEARTBEAT_EVERY_S=10
MONITOR_EDGE_SYNC_TIMEOUT_S=5
MONITOR_EDGE_SYNC_VERIFY_SSL=true
MONITOR_EDGE_SYNC_DRAIN_EVERY_S=2
MONITOR_EDGE_SYNC_DRAIN_BATCH_SIZE=8
MONITOR_EDGE_SYNC_MAX_CONTEXT_BYTES=2000000
MONITOR_OUTPUT_DATA=/app/data/elevator_rt_live.csv
MONITOR_OUTPUT_ALERT=/app/data/elevator_alerts_live.csv
MONITOR_OUTPUT_RAIL_WEAR=/app/data/rail_wear_alerts_live.csv
MONITOR_ALERT_CONTEXT_ENABLED=true
MONITOR_ALERT_CONTEXT_DIR=/app/data/alert_context
MONITOR_ALERT_CONTEXT_PRE_SECONDS=30
MONITOR_ALERT_CONTEXT_MAX_ROWS=6000
MONITOR_PROFILE_PATH=/app/data/profiles/{elevator_id}.json
MONITOR_PROFILE_SAVE_EVERY_N=300
MONITOR_PROFILE_MAX_ITEMS=3000
MONITOR_HEALTH_PATH=/app/data/monitor_health.json
MONITOR_LOG_FILE=/app/logs/realtime_monitor.log

# Host <-> container serial mapping
MONITOR_DEVICE_HOST=/dev/ttyUSB0
MONITOR_DEVICE_CONTAINER=/dev/ttyUSB0
